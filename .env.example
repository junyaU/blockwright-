# Claude API キー（必須）。リポジトリにコミットしないこと。
ANTHROPIC_API_KEY=

# WS サーバーのポート（既定 19131）
PORT=19131

# 発言→IR 生成に使うモデル
MODEL=claude-sonnet-4-6

# --- v4「喋るだけ」パイプライン（任意・個人ローカル利用限定） ---
# 未設定なら v4 は自動スキップ（既存のパラメトリック経路のみ動作）。
# ② 画像取得（既定 SerpAPI）。設定すると「○○作って」がキャラ建築経路に入る。
SERPAPI_API_KEY=
# ③ image→3D 生成（Meshy）。未設定/失敗時は v3.0 平面建築にフォールバック。
MESHY_API_KEY=

# --- v5 ---
# サイズ無指定のキャラ生成の既定の高さ（ブロック数・既定 48）。
# grid 各軸の上限は 64。横長キャラ（比 ~1.2）は 56 付近で幅が頭打ちし高さがやや縮む。
# 大きくするほど設置コマンド数が増え、設置が重くなる点に注意。
DEFAULT_CHARACTER_HEIGHT=56

# --- v6 経路ルーター＋リファレンス識別（すべて任意・既定で動く） ---
# 曖昧/低信頼時の経路ポリシー：generation=生成寄り（既定）/ confirm=1問確認（§6.4）。
V6_AMBIGUITY_POLICY=generation
# 固有の参照同定不能時：notify=通知して停止（既定・黙って建てない）/ flat=最良候補で試行（§6.5）。
V6_UNIDENTIFIED_POLICY=notify
# 分類の信頼度しきい値。これ未満は曖昧扱い（既定 0.6）。
V6_CLASSIFY_CONFIDENCE=0.6
# リファレンス識別で取得・検証する候補画像数（既定 8。webp/avif 脱落分の余裕）。
V6_REF_CANDIDATES=8
# vision 検証の採用スコアしきい値 0..1（既定 0.6。固有=strict はこれを底上げ）。
V6_REF_MIN_SCORE=0.6
# vision 検証に使うモデル（未設定なら MODEL を流用）。
VISION_MODEL=claude-sonnet-4-6
